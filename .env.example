# ---- Telephony (Twilio) ----
# From your Twilio console. The FROM number must be a Twilio number you own,
# in E.164 format. This is the single number you report on the submission form.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ---- AI services ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx        # the "patient" brain + bug analysis
DEEPGRAM_API_KEY=xxxxxxxx                 # speech-to-text
CARTESIA_API_KEY=sk_car_xxxxxxxx          # text-to-speech

# ---- ngrok (public URL for Twilio -> your local server) ----
# Free token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken

# ---- Optional overrides (sensible defaults exist) ----
# ANTHROPIC_MODEL=claude-sonnet-4-6       # patient brain; use claude-haiku-4-5 for lower latency
# ANALYSIS_MODEL=claude-opus-4-8          # bug-report writer
# CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121
# DEEPGRAM_MODEL=nova-3
# PORT=8765
